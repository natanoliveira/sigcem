# ═══════════════════════════════════════════════════════════
# SIGCEM — Variáveis de Produção
# Copie para .env.prod e preencha com os valores reais.
# NUNCA commite .env.prod no repositório.
# ═══════════════════════════════════════════════════════════

# ── Banco de dados (Neon / PostgreSQL) ─────────────────────
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/sigcem?sslmode=require

# ── API ────────────────────────────────────────────────────
API_PORT=3001
# Chave de 32+ chars para AES-256 (LGPD: CPF e causa mortis)
ENCRYPTION_KEY=troque-por-uma-chave-longa-e-aleatoria-aqui

# ── Next.js / NextAuth ─────────────────────────────────────
NEXTAUTH_URL=https://sigcem.municipio.gov.br
# openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-secret-gerado-com-openssl

# URL interna usada pelo servidor Next.js para chamar a API
NEXT_PUBLIC_API_URL=https://api.sigcem.municipio.gov.br

# ── Keycloak ───────────────────────────────────────────────
# Banco dedicado para o Keycloak (pode ser o mesmo Neon com schema diferente)
KEYCLOAK_DB_URL=jdbc:postgresql://host.neon.tech/sigcem_keycloak?sslmode=require
KEYCLOAK_DB_USERNAME=keycloak_user
KEYCLOAK_DB_PASSWORD=senha-do-keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=senha-admin-keycloak
# Hostname público do Keycloak (sem https://)
KEYCLOAK_HOSTNAME=auth.sigcem.municipio.gov.br

# URL usada pela API para validar tokens JWT
KEYCLOAK_ISSUER=https://auth.sigcem.municipio.gov.br/realms/sigcem
KEYCLOAK_AUDIENCE=sigcem-api

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD=senha-forte-para-redis

# ── MinIO ──────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio-access-key-forte
MINIO_SECRET_KEY=minio-secret-key-forte-64-chars-minimo
# URL pública do console MinIO (para redirect do browser)
MINIO_CONSOLE_URL=https://minio-console.sigcem.municipio.gov.br
