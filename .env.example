# ── Banco de Dados (Neon) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require&channel_binding=require"
DIRECT_DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require&channel_binding=require"

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_INTERNAL_URL="http://keycloak:8080"
KEYCLOAK_PUBLIC_URL="http://localhost:8080"
KEYCLOAK_REALM="sigcem"
KEYCLOAK_CLIENT_ID="sigcem-api"
KEYCLOAK_CLIENT_SECRET="your-client-secret"
KEYCLOAK_ADMIN="admin"
KEYCLOAK_ADMIN_PASSWORD="strong-admin-password"

# Keycloak DB (Neon — use a URL direta, sem -pooler no host)
KEYCLOAK_DB_URL="jdbc:postgresql://<host-direto>.neon.tech/<dbname>?sslmode=require"
KEYCLOAK_DB_USERNAME="neondb_owner"
KEYCLOAK_DB_PASSWORD="sua-senha-neon-keycloak"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_USE_SSL="false"

# ── API (NestJS) ──────────────────────────────────────────────────────────────
API_PORT="3001"
NODE_ENV="development"

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_KEYCLOAK_URL="http://localhost:8080"
NEXT_PUBLIC_KEYCLOAK_REALM="sigcem"
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="gere com: openssl rand -base64 32"

# ── Criptografia (LGPD) ───────────────────────────────────────────────────────
ENCRYPTION_KEY="gere com: openssl rand -hex 32"
