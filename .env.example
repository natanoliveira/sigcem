# ── Keycloak (usado pelo docker-compose) ──────────────────────────────────────
KEYCLOAK_ADMIN="admin"
KEYCLOAK_ADMIN_PASSWORD="strong-admin-password"
KEYCLOAK_DB_URL="jdbc:postgresql://<host-direto>.neon.tech/<dbname>?sslmode=require"
KEYCLOAK_DB_USERNAME="neondb_owner"
KEYCLOAK_DB_PASSWORD="sua-senha-neon"

# ── MinIO (usado pelo docker-compose) ─────────────────────────────────────────
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
