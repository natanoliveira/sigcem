generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  DOCUMENT_AGENT
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum GraveType {
  SINGLE
  DOUBLE
  DRAWER
  OSSUARY
  PERPETUAL
}

enum GraveStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  BLOCKED
}

enum BurialType {
  INHUMATION
  EXHUMATION
  TRANSFER
}

enum DocumentType {
  CERTIFICATE
  AUTHORIZATION
  PHOTO
  ATTACHMENT
}

enum SystemModule {
  CEMETERIES
  BLOCKS
  GRAVES
  DECEASED
  BURIALS
  DOCUMENTS
  AUDIT
  USERS
  GROUPS
}

enum PermissionAction {
  CREATE
  VIEW
  EDIT
  DELETE
}

// ── Tenant ───────────────────────────────────────────────────────────────────

model Tenant {
  id         String      @id @default(uuid())
  name       String
  domain     String      @unique
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now()) @map("created_at")
  users      User[]
  cemeteries Cemetery[]
  groups     Group[]

  @@map("tenants")
}

// ── User ─────────────────────────────────────────────────────────────────────

model User {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  keycloakId String?   @unique @map("keycloak_id")
  name       String
  email      String
  password   String
  role       UserRole
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  groups     GroupMember[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ── Cemetery ─────────────────────────────────────────────────────────────────

model Cemetery {
  id           String       @id @default(uuid())
  tenantId     String       @map("tenant_id")
  name         String
  address      String
  neighborhood String?
  areaM2       Decimal?     @map("area_m2")
  capacity     Int?
  status       EntityStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  blocks       Block[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@map("cemeteries")
}

// ── Block ────────────────────────────────────────────────────────────────────

model Block {
  id         String       @id @default(uuid())
  tenantId   String       @map("tenant_id")
  cemeteryId String       @map("cemetery_id")
  code       String
  name       String?
  capacity   Int?
  status     EntityStatus @default(ACTIVE)
  createdAt  DateTime     @default(now()) @map("created_at")
  cemetery   Cemetery     @relation(fields: [cemeteryId], references: [id])
  graves     Grave[]

  @@unique([cemeteryId, code])
  @@index([tenantId])
  @@map("blocks")
}

// ── Grave ────────────────────────────────────────────────────────────────────

model Grave {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  blockId     String      @map("block_id")
  code        String
  type        GraveType
  status      GraveStatus @default(AVAILABLE)
  locationRef String?     @map("location_ref")
  notes       String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  block       Block       @relation(fields: [blockId], references: [id])
  history     GraveHistory[]
  burials     Burial[]

  @@unique([blockId, code])
  @@index([tenantId, status])
  @@map("graves")
}

// ── Grave History ─────────────────────────────────────────────────────────────

model GraveHistory {
  id             String      @id @default(uuid())
  graveId        String      @map("grave_id")
  previousStatus GraveStatus @map("previous_status")
  newStatus      GraveStatus @map("new_status")
  reason         String?
  userId         String      @map("user_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  grave          Grave       @relation(fields: [graveId], references: [id])

  @@index([graveId])
  @@map("grave_history")
}

// ── Deceased ─────────────────────────────────────────────────────────────────

model Deceased {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  fullName        String    @map("full_name")
  birthDate       DateTime  @map("birth_date")
  deathDate       DateTime  @map("death_date")
  taxIdHash       String?   @map("tax_id_hash")
  causeOfDeathEnc String?   @map("cause_of_death_enc")
  birthPlace      String?   @map("birth_place")
  nationality     String?
  fatherName      String?   @map("father_name")
  motherName      String?   @map("mother_name")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  burials         Burial[]

  @@index([tenantId, fullName])
  @@map("deceased")
}

// ── Burial ───────────────────────────────────────────────────────────────────

model Burial {
  id               String     @id @default(uuid())
  tenantId         String     @map("tenant_id")
  deceasedId       String     @map("deceased_id")
  graveId          String     @map("grave_id")
  type             BurialType
  eventDate        DateTime   @map("event_date")
  funeralHome      String?    @map("funeral_home")
  responsibleName  String?    @map("responsible_name")
  responsibleTaxId String?    @map("responsible_tax_id")
  authorizedBy     String     @map("authorized_by")
  notes            String?
  createdAt        DateTime   @default(now()) @map("created_at")
  deceased         Deceased   @relation(fields: [deceasedId], references: [id])
  grave            Grave      @relation(fields: [graveId], references: [id])

  @@index([tenantId])
  @@index([deceasedId])
  @@index([graveId])
  @@map("burials")
}

// ── Document ─────────────────────────────────────────────────────────────────

model Document {
  id         String       @id @default(uuid())
  tenantId   String       @map("tenant_id")
  type       DocumentType
  entityType String       @map("entity_type")
  entityId   String       @map("entity_id")
  fileName   String       @map("file_name")
  storageKey String       @map("storage_key")
  issuedAt   DateTime     @default(now()) @map("issued_at")
  issuedBy   String       @map("issued_by")
  active     Boolean      @default(true)

  @@index([tenantId, entityType, entityId])
  @@map("documents")
}

// ── Group ─────────────────────────────────────────────────────────────────────

model Group {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  members     GroupMember[]
  permissions GroupPermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("groups")
}

model GroupMember {
  groupId String @map("group_id")
  userId  String @map("user_id")
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_members")
}

model GroupPermission {
  id      String             @id @default(uuid())
  groupId String             @map("group_id")
  module  SystemModule
  actions PermissionAction[]
  group   Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, module])
  @@map("group_permissions")
}

// ── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  userId       String   @map("user_id")
  action       String
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  previousData Json?    @map("previous_data")
  newData      Json?    @map("new_data")
  ip           String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}
